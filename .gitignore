# Замените содержимое .gitignore:
cat > .gitignore << EOF
# Dependencies
node_modules/
npm-debug.log*

# Production build
dist/
build/

# Environment
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# VS Code
.vscode/settings.json

# OS
.DS_Store
Thumbs.db
EOF

git add .gitignore
git commit -m "Fix .gitignore"
git push